# ── HORIZON Web — Variables de entorno ────────────────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees .env al repositorio.

# Puerto del servidor Express (EasyPanel/Railway lo asigna automáticamente)
PORT=3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# URL del proyecto Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anon (pública) — solo para lectura desde cliente si el RLS lo permite
SUPABASE_ANON_KEY=eyJhbGc...

# Clave service_role (PRIVADA) — usar solo en backend/serverless, NUNCA en cliente
# Bypasea RLS. No exponer jamás en HTML ni código frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── n8n ───────────────────────────────────────────────────────────────────────
# Webhook de n8n que recibe leads del sitio
# Solo HTTPS. No usar localhost.
N8N_WEBHOOK_URL=https://horizon-n8n.tmae4w.easypanel.host/webhook/horizon-leads

# Webhook de n8n para confirmaciones de booking (schedule-meet)
N8N_BOOKING_WEBHOOK=https://horizon-n8n.tmae4w.easypanel.host/webhook/horizon-booking

# ── Cal.com ───────────────────────────────────────────────────────────────────
# Secret para verificar firma HMAC de webhooks de Cal.com
# Configurar en: Cal.com → Settings → Webhooks → Secret
CAL_COM_WEBHOOK_SECRET=tu-secret-aqui

# ── Google Calendar (para /api/schedule-meet) ─────────────────────────────────
# Obtener en: console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu-client-secret
GOOGLE_REFRESH_TOKEN=tu-refresh-token
# ID del calendario donde se crean los eventos (puede ser tu email de Google)
GOOGLE_CALENDAR_ID=tu-email@gmail.com
