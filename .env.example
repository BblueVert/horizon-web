# ── HORIZON Web — Variables de entorno ────────────────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees .env al repositorio.

# ── Supabase HORIZON (proyecto principal) ─────────────────────────────────────
SUPABASE_URL=https://TU_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key_aqui

# ── n8n Webhooks ───────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://tu-n8n.host/webhook/horizon-leads
N8N_BOOKING_WEBHOOK=https://tu-n8n.host/webhook/booking

# ── Anthropic (Agente HORIZON — Módulo D) ─────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...tu_clave_aqui

# ── Google Calendar (agenda de reuniones) ─────────────────────────────────────
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=1//0g...
GOOGLE_CALENDAR_ID=tu_email@gmail.com

# ── Supabase SaaS (proyecto peluquerías — horizon-saas) ───────────────────────
# Solo service_role para endpoints de servidor.
SUPABASE_SAAS_URL=https://TU_SAAS_REF.supabase.co
SUPABASE_SAAS_SERVICE_KEY=eyJ...saas_service_role_key_aqui