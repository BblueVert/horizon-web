# HORIZON Web — Variables de entorno requeridas
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el archivo .env con valores reales.

# ── n8n Automation ──────────────────────────────────────────
# URL base de la instancia de n8n
N8N_API_URL=https://tu-instancia-n8n.dominio.com/api/v1

# API Key de n8n (Settings → API → Create API Key)
# Esta clave va también en Skills Juanpe/kit-automatizaciones-n8n/.mcp.json
N8N_API_KEY=REEMPLAZAR_CON_TU_API_KEY_DE_N8N

# URL de webhooks de n8n
N8N_WEBHOOK_URL=https://tu-instancia-n8n.dominio.com

# ── Supabase (CRM / Base de datos) ──────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=REEMPLAZAR
SUPABASE_SERVICE_ROLE_KEY=REEMPLAZAR

# ── Cal.com ─────────────────────────────────────────────────
CAL_API_KEY=REEMPLAZAR

# ── Contacto público (no son secretos, solo referencia) ─────
WHATSAPP_NUMBER=56912345678
INSTAGRAM_HANDLE=horizon.webs
DOMAIN=horizonweb.cl
